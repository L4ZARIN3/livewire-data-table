{
    "name": "lazarini/livewire-data-table",
    "description": "Reusable dynamic table package for Laravel Livewire 4 with declarative columns and filters.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "livewire",
        "datatable",
        "table",
        "lazarini"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/pagination": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "livewire/livewire": "^3.5 || ^4.0"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Lazarini\\LivewireDataTable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lazarini\\LivewireDataTable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lazarini\\LivewireDataTable\\LivewireDataTableServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}